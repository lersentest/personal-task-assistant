{
  "name": "personal-task-assistant",
  "version": "0.1.0",
  "description": "Personal Telegram bot for confirmed project and task creation",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "prisma generate && nest build",
    "start": "node dist/main.js",
    "start:dev": "prisma generate && nest start --watch",
    "db:smoke": "node scripts/database-smoke.mjs",
    "openai:smoke": "node scripts/openai-smoke.mjs",
    "openai:audio-smoke": "node scripts/openai-audio-smoke.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "typecheck": "prisma generate && tsc --noEmit",
    "test": "npm run build && node --test \"dist/**/*.test.js\""
  },
  "dependencies": {
    "@nestjs/common": "11.1.28",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-express": "11.1.28",
    "@nestjs/schedule": "^6.1.3",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "dotenv": "17.4.2",
    "grammy": "1.44.0",
    "luxon": "^3.7.2",
    "openai": "^6.46.0",
    "pg": "8.22.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.24",
    "@types/luxon": "^3.7.2",
    "@types/node": "24.13.3",
    "@types/pg": "8.20.0",
    "prisma": "7.8.0",
    "typescript": "5.9.3"
  },
  "overrides": {
    "@hono/node-server": "1.19.13"
  }
}
