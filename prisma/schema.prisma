generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

enum TaskStatus {
  NEW
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum DueDateType {
  ON_DATE
  BEFORE_DATE
  EXACT_TIME
}

enum TaskSourceType {
  TEXT
  VOICE
  FORWARDED_MESSAGE
}

enum ReminderType {
  CUSTOM
  DAY_BEFORE
  DUE_DATE
  OVERDUE
  SNOOZE
}

enum ReminderStatus {
  PENDING
  SENT
  CANCELLED
}

model User {
  id             String   @id @default(uuid()) @db.Uuid
  telegramId     BigInt   @unique @map("telegram_id")
  authUserId     String?  @unique @map("auth_user_id") @db.Uuid
  username       String?  @db.VarChar(255)
  firstName      String   @map("first_name") @db.VarChar(255)
  lastName       String?  @map("last_name") @db.VarChar(255)
  languageCode   String?  @map("language_code") @db.VarChar(16)
  timezone       String   @default("Europe/Zurich") @db.VarChar(64)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  ownedProjects   Project[] @relation("ProjectOwner")
  createdProjects Project[] @relation("ProjectCreator")
  ownedTasks      Task[]    @relation("TaskOwner")
  createdTasks    Task[]    @relation("TaskCreator")
  assignedTasks   Task[]    @relation("TaskAssignee")
  tags            Tag[]
  attachments     Attachment[] @relation("AttachmentOwner")
  uploadedFiles   Attachment[] @relation("AttachmentUploader")
  dailySummaries  DailySummaryDelivery[]

  @@map("users")
}

model Project {
  id          String        @id @default(uuid()) @db.Uuid
  ownerId     String        @map("owner_id") @db.Uuid
  createdById String        @map("created_by_id") @db.Uuid
  name        String        @db.VarChar(200)
  description String?       @db.Text
  status      ProjectStatus @default(ACTIVE)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)
  archivedAt  DateTime?     @map("archived_at") @db.Timestamptz(3)
  deletedAt   DateTime?     @map("deleted_at") @db.Timestamptz(3)

  owner     User   @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  createdBy User   @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: Restrict)
  tasks     Task[]
  attachments Attachment[]

  @@unique([ownerId, name])
  @@index([ownerId, status, deletedAt])
  @@map("projects")
}

model Task {
  id           String         @id @default(uuid()) @db.Uuid
  ownerId      String         @map("owner_id") @db.Uuid
  createdById  String         @map("created_by_id") @db.Uuid
  assigneeId   String         @map("assignee_id") @db.Uuid
  projectId    String?        @map("project_id") @db.Uuid
  title        String         @db.VarChar(500)
  description  String?        @db.Text
  status       TaskStatus     @default(NEW)
  priority     TaskPriority   @default(NORMAL)
  dueAt        DateTime?      @map("due_at") @db.Timestamptz(3)
  dueDateType  DueDateType?   @map("due_date_type")
  remindAt     DateTime?      @map("remind_at") @db.Timestamptz(3)
  sourceType   TaskSourceType @default(TEXT) @map("source_type")
  originalText String?        @map("original_text") @db.Text
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)
  completedAt  DateTime?      @map("completed_at") @db.Timestamptz(3)
  cancelledAt  DateTime?      @map("cancelled_at") @db.Timestamptz(3)
  deletedAt    DateTime?      @map("deleted_at") @db.Timestamptz(3)

  owner     User     @relation("TaskOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  createdBy User     @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Restrict)
  assignee  User     @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: Restrict)
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  tags      TaskTag[]
  reminders Reminder[]
  attachments Attachment[]

  @@index([ownerId, status, deletedAt])
  @@index([ownerId, dueAt])
  @@index([projectId, status, deletedAt])
  @@map("tasks")
}

model Tag {
  id             String   @id @default(uuid()) @db.Uuid
  ownerId        String   @map("owner_id") @db.Uuid
  name           String   @db.VarChar(80)
  normalizedName String   @map("normalized_name") @db.VarChar(80)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  owner User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tasks TaskTag[]

  @@unique([ownerId, normalizedName])
  @@index([ownerId, name])
  @@map("tags")
}

model TaskTag {
  taskId     String   @map("task_id") @db.Uuid
  tagId      String   @map("tag_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz(3)

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@index([tagId, taskId])
  @@map("task_tags")
}

model Reminder {
  id        String         @id @default(uuid()) @db.Uuid
  taskId    String         @map("task_id") @db.Uuid
  remindAt  DateTime       @map("remind_at") @db.Timestamptz(3)
  type      ReminderType   @default(CUSTOM)
  status    ReminderStatus @default(PENDING)
  sentAt    DateTime?      @map("sent_at") @db.Timestamptz(3)
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([status, remindAt])
  @@index([taskId, status])
  @@map("reminders")
}

model DailySummaryDelivery {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  localDate String   @map("local_date") @db.VarChar(10)
  sentAt    DateTime @default(now()) @map("sent_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, localDate])
  @@map("daily_summary_deliveries")
}

model Attachment {
  id           String   @id @default(uuid()) @db.Uuid
  ownerId      String   @map("owner_id") @db.Uuid
  uploadedById String   @map("uploaded_by_id") @db.Uuid
  taskId       String?  @map("task_id") @db.Uuid
  projectId    String?  @map("project_id") @db.Uuid
  fileName     String   @map("file_name") @db.VarChar(255)
  mimeType     String   @map("mime_type") @db.VarChar(255)
  sizeBytes    Int      @map("size_bytes")
  data         Bytes
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(3)

  owner      User     @relation("AttachmentOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  uploadedBy User     @relation("AttachmentUploader", fields: [uploadedById], references: [id], onDelete: Restrict)
  task       Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  project    Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([ownerId, createdAt])
  @@index([taskId])
  @@index([projectId])
  @@map("attachments")
}
