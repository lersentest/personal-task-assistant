generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

enum TaskStatus {
  NEW
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum DueDateType {
  ON_DATE
  BEFORE_DATE
  EXACT_TIME
}

enum TaskSourceType {
  TEXT
  VOICE
  FORWARDED_MESSAGE
}

enum TaskKind {
  TASK
  CALL
  MEETING
  IDEA
  NOTE
}

enum ActivityEventType {
  TASK_CREATED
  TASK_UPDATED
  TASK_COMPLETED
  TASK_DELETED
  PROJECT_CREATED
  PROJECT_UPDATED
  FILE_ADDED
}

enum ReminderType {
  CUSTOM
  DAY_BEFORE
  DUE_DATE
  OVERDUE
  SNOOZE
}

enum ReminderStatus {
  PENDING
  SENT
  CANCELLED
}

enum DailyPlanScheduleType {
  FLEXIBLE
  FIXED
}

enum ExecutorLanguage {
  RU
  UK
  EN
  DE
}

enum ExecutorConnectionStatus {
  NOT_CONNECTED
  INVITE_CREATED
  CONNECTED
  INACTIVE
}

enum DelegatedTaskStatus {
  DRAFT
  SENT
  ACCEPTED
  IN_PROGRESS
  QUESTION
  WAITING_REVIEW
  RETURNED
  COMPLETED
  CANCELLED
}

enum DelegatedTaskCommentAuthor {
  OWNER
  EXECUTOR
  SYSTEM
}

enum DelegatedTaskEventType {
  CREATED
  UPDATED
  SENT
  ACCEPTED
  STARTED
  QUESTION_ASKED
  OWNER_REPLIED
  SUBMITTED
  ACCEPTED_BY_OWNER
  RETURNED
  CANCELLED
  REMINDED
  REASSIGNED
  FILE_ADDED
}

enum DelegatedReminderType {
  MANUAL
  DAY_BEFORE
  DUE_DATE
  OVERDUE
  DIGEST
}

enum AiAnalyticsMessageRole {
  USER
  ASSISTANT
}

model User {
  id             String   @id @default(uuid()) @db.Uuid
  telegramId     BigInt   @unique @map("telegram_id")
  authUserId     String?  @unique @map("auth_user_id") @db.Uuid
  username       String?  @db.VarChar(255)
  firstName      String   @map("first_name") @db.VarChar(255)
  lastName       String?  @map("last_name") @db.VarChar(255)
  languageCode   String?  @map("language_code") @db.VarChar(16)
  timezone       String   @default("Europe/Zurich") @db.VarChar(64)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  ownedProjects   Project[] @relation("ProjectOwner")
  createdProjects Project[] @relation("ProjectCreator")
  ownedTasks      Task[]    @relation("TaskOwner")
  createdTasks    Task[]    @relation("TaskCreator")
  assignedTasks   Task[]    @relation("TaskAssignee")
  tags            Tag[]
  attachments     Attachment[] @relation("AttachmentOwner")
  uploadedFiles   Attachment[] @relation("AttachmentUploader")
  dailySummaries  DailySummaryDelivery[]
  dailyPlanItems  DailyPlanItem[]
  activityEvents  ActivityEvent[]
  executors       Executor[]
  delegatedTasks  DelegatedTask[] @relation("DelegatedTaskOwner")
  delegatedEvents DelegatedTaskEvent[]
  aiAnalyticsConversations AiAnalyticsConversation[]
  aiAnalyticsMessages      AiAnalyticsMessage[]
  auditAccessGrants        AuditAccessGrant[]
  auditSessions            AuditSession[]

  @@map("users")
}

model AuditAccessGrant {
  id        String    @id @default(uuid()) @db.Uuid
  ownerId   String    @map("owner_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(128)
  label     String?   @db.VarChar(200)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(3)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  owner    User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  sessions AuditSession[]

  @@index([ownerId, revokedAt, expiresAt])
  @@map("audit_access_grants")
}

model AuditSession {
  id          String    @id @default(uuid()) @db.Uuid
  grantId     String    @map("grant_id") @db.Uuid
  ownerId     String    @map("owner_id") @db.Uuid
  sessionHash String    @unique @map("session_hash") @db.VarChar(128)
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz(3)
  lastSeenAt  DateTime? @map("last_seen_at") @db.Timestamptz(3)
  revokedAt   DateTime? @map("revoked_at") @db.Timestamptz(3)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  grant AuditAccessGrant @relation(fields: [grantId], references: [id], onDelete: Cascade)
  owner User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, revokedAt, expiresAt])
  @@index([grantId, revokedAt])
  @@map("audit_sessions")
}

model Project {
  id          String        @id @default(uuid()) @db.Uuid
  ownerId     String        @map("owner_id") @db.Uuid
  createdById String        @map("created_by_id") @db.Uuid
  name        String        @db.VarChar(200)
  description String?       @db.Text
  status      ProjectStatus @default(ACTIVE)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)
  archivedAt  DateTime?     @map("archived_at") @db.Timestamptz(3)
  deletedAt   DateTime?     @map("deleted_at") @db.Timestamptz(3)

  owner     User   @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  createdBy User   @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: Restrict)
  tasks     Task[]
  attachments Attachment[]
  delegatedTasks DelegatedTask[]

  @@unique([ownerId, name])
  @@index([ownerId, status, deletedAt])
  @@map("projects")
}

model Executor {
  id                 String                   @id @default(uuid()) @db.Uuid
  ownerId            String                   @map("owner_id") @db.Uuid
  fullName           String                   @map("full_name") @db.VarChar(255)
  company            String?                  @db.VarChar(255)
  role               String?                  @db.VarChar(255)
  email              String?                  @db.VarChar(255)
  phone              String?                  @db.VarChar(64)
  telegramUserId     BigInt?                  @map("telegram_user_id")
  telegramUsername   String?                  @map("telegram_username") @db.VarChar(255)
  telegramFirstName  String?                  @map("telegram_first_name") @db.VarChar(255)
  telegramLastName   String?                  @map("telegram_last_name") @db.VarChar(255)
  language           ExecutorLanguage         @default(RU)
  timezone           String                   @default("Europe/Zurich") @db.VarChar(64)
  dailyDigestEnabled Boolean                  @default(true) @map("daily_digest_enabled")
  dailyDigestTime    String                   @default("08:00") @map("daily_digest_time") @db.VarChar(5)
  connectionStatus   ExecutorConnectionStatus @default(NOT_CONNECTED) @map("connection_status")
  isActive           Boolean                  @default(true) @map("is_active")
  connectedAt        DateTime?                @map("connected_at") @db.Timestamptz(3)
  createdAt          DateTime                 @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(3)
  archivedAt         DateTime?                @map("archived_at") @db.Timestamptz(3)
  deletedAt          DateTime?                @map("deleted_at") @db.Timestamptz(3)

  owner          User                   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  invites        ExecutorInvite[]
  delegatedTasks DelegatedTask[]
  comments       DelegatedTaskComment[]
  events         DelegatedTaskEvent[]

  @@unique([ownerId, telegramUserId])
  @@index([ownerId, deletedAt])
  @@index([ownerId, connectionStatus, isActive])
  @@map("executors")
}

model ExecutorInvite {
  id        String    @id @default(uuid()) @db.Uuid
  executorId String   @map("executor_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(128)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(3)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(3)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  executor Executor @relation(fields: [executorId], references: [id], onDelete: Cascade)

  @@index([executorId, createdAt])
  @@index([expiresAt])
  @@map("executor_invites")
}

model DelegatedTask {
  id           String              @id @default(uuid()) @db.Uuid
  ownerId      String              @map("owner_id") @db.Uuid
  executorId   String              @map("executor_id") @db.Uuid
  projectId    String?             @map("project_id") @db.Uuid
  title        String              @db.VarChar(500)
  description  String?             @db.Text
  resultText   String?             @map("result_text") @db.Text
  status       DelegatedTaskStatus @default(DRAFT)
  priority     TaskPriority        @default(NORMAL)
  dueAt        DateTime?           @map("due_at") @db.Timestamptz(3)
  sentAt       DateTime?           @map("sent_at") @db.Timestamptz(3)
  acceptedAt   DateTime?           @map("accepted_at") @db.Timestamptz(3)
  startedAt    DateTime?           @map("started_at") @db.Timestamptz(3)
  submittedAt  DateTime?           @map("submitted_at") @db.Timestamptz(3)
  returnedAt   DateTime?           @map("returned_at") @db.Timestamptz(3)
  completedAt  DateTime?           @map("completed_at") @db.Timestamptz(3)
  cancelledAt  DateTime?           @map("cancelled_at") @db.Timestamptz(3)
  lastReminderAt DateTime?         @map("last_reminder_at") @db.Timestamptz(3)
  publicAccessToken String         @unique @default(uuid()) @map("public_access_token") @db.Uuid
  publicAccessRevokedAt DateTime?  @map("public_access_revoked_at") @db.Timestamptz(3)
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt    DateTime?           @map("deleted_at") @db.Timestamptz(3)

  owner     User     @relation("DelegatedTaskOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  executor  Executor @relation(fields: [executorId], references: [id], onDelete: Restrict)
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  comments  DelegatedTaskComment[]
  events    DelegatedTaskEvent[]
  reminders DelegatedTaskReminder[]
  attachments Attachment[]

  @@index([ownerId, status, deletedAt])
  @@index([ownerId, dueAt])
  @@index([executorId, status, deletedAt])
  @@index([projectId, status, deletedAt])
  @@index([publicAccessToken, publicAccessRevokedAt])
  @@map("delegated_tasks")
}

model DelegatedTaskComment {
  id          String                     @id @default(uuid()) @db.Uuid
  taskId      String                     @map("task_id") @db.Uuid
  ownerId     String                     @map("owner_id") @db.Uuid
  executorId  String?                    @map("executor_id") @db.Uuid
  author      DelegatedTaskCommentAuthor
  message     String                     @db.Text
  createdAt   DateTime                   @default(now()) @map("created_at") @db.Timestamptz(3)
  deletedAt   DateTime?                  @map("deleted_at") @db.Timestamptz(3)

  task     DelegatedTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  executor Executor?     @relation(fields: [executorId], references: [id], onDelete: SetNull)

  @@index([taskId, createdAt])
  @@index([ownerId, createdAt])
  @@map("delegated_task_comments")
}

model DelegatedTaskEvent {
  id          String                 @id @default(uuid()) @db.Uuid
  taskId      String                 @map("task_id") @db.Uuid
  ownerId     String                 @map("owner_id") @db.Uuid
  executorId  String?                @map("executor_id") @db.Uuid
  type        DelegatedTaskEventType
  title       String                 @db.VarChar(500)
  metadata    Json?
  createdAt   DateTime               @default(now()) @map("created_at") @db.Timestamptz(3)

  task     DelegatedTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  owner    User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  executor Executor?     @relation(fields: [executorId], references: [id], onDelete: SetNull)

  @@index([ownerId, createdAt])
  @@index([taskId, createdAt])
  @@map("delegated_task_events")
}

model DelegatedTaskReminder {
  id        String            @id @default(uuid()) @db.Uuid
  taskId    String            @map("task_id") @db.Uuid
  remindAt  DateTime          @map("remind_at") @db.Timestamptz(3)
  type      DelegatedReminderType @default(MANUAL)
  status    ReminderStatus    @default(PENDING)
  sentAt    DateTime?         @map("sent_at") @db.Timestamptz(3)
  createdAt DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)

  task DelegatedTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([status, remindAt])
  @@index([taskId, status])
  @@map("delegated_task_reminders")
}

model Task {
  id           String         @id @default(uuid()) @db.Uuid
  ownerId      String         @map("owner_id") @db.Uuid
  createdById  String         @map("created_by_id") @db.Uuid
  assigneeId   String         @map("assignee_id") @db.Uuid
  projectId    String?        @map("project_id") @db.Uuid
  title        String         @db.VarChar(500)
  description  String?        @db.Text
  status       TaskStatus     @default(NEW)
  priority     TaskPriority   @default(NORMAL)
  kind         TaskKind        @default(TASK)
  isFlexible   Boolean         @default(true) @map("is_flexible")
  dueAt        DateTime?      @map("due_at") @db.Timestamptz(3)
  dueDateType  DueDateType?   @map("due_date_type")
  remindAt     DateTime?      @map("remind_at") @db.Timestamptz(3)
  estimatedDurationMinutes Int? @map("estimated_duration_minutes")
  sourceType   TaskSourceType @default(TEXT) @map("source_type")
  originalText String?        @map("original_text") @db.Text
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)
  completedAt  DateTime?      @map("completed_at") @db.Timestamptz(3)
  cancelledAt  DateTime?      @map("cancelled_at") @db.Timestamptz(3)
  deletedAt    DateTime?      @map("deleted_at") @db.Timestamptz(3)

  owner     User     @relation("TaskOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  createdBy User     @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Restrict)
  assignee  User     @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: Restrict)
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  tags      TaskTag[]
  reminders Reminder[]
  attachments Attachment[]
  dailyPlanItems DailyPlanItem[]
  activityEvents ActivityEvent[]
  checklistItems TaskChecklistItem[]

  @@index([ownerId, status, deletedAt])
  @@index([ownerId, kind, deletedAt])
  @@index([ownerId, status, deletedAt, dueAt])
  @@index([ownerId, status, deletedAt, updatedAt])
  @@index([ownerId, dueAt])
  @@index([projectId, status, deletedAt])
  @@map("tasks")
}

model TaskChecklistItem {
  id          String    @id @default(uuid()) @db.Uuid
  taskId      String    @map("task_id") @db.Uuid
  title       String    @db.VarChar(500)
  isCompleted Boolean   @default(false) @map("is_completed")
  position    Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  completedAt DateTime? @map("completed_at") @db.Timestamptz(3)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(3)

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, deletedAt, position])
  @@map("task_checklist_items")
}

model DailyPlanItem {
  id                  String                @id @default(uuid()) @db.Uuid
  userId              String                @map("user_id") @db.Uuid
  taskId              String                @map("task_id") @db.Uuid
  date                DateTime              @db.Date
  order               Int                   @default(0)
  scheduledStartAt    DateTime?             @map("scheduled_start_at") @db.Timestamptz(3)
  scheduledEndAt      DateTime?             @map("scheduled_end_at") @db.Timestamptz(3)
  scheduleType        DailyPlanScheduleType @default(FLEXIBLE) @map("schedule_type")
  addedAt             DateTime              @default(now()) @map("added_at") @db.Timestamptz(3)
  removedAt           DateTime?             @map("removed_at") @db.Timestamptz(3)
  completedInPlanAt   DateTime?             @map("completed_in_plan_at") @db.Timestamptz(3)
  createdAt           DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([userId, date, removedAt])
  @@index([taskId, date])
  @@map("daily_plan_items")
}

model Tag {
  id             String   @id @default(uuid()) @db.Uuid
  ownerId        String   @map("owner_id") @db.Uuid
  name           String   @db.VarChar(80)
  normalizedName String   @map("normalized_name") @db.VarChar(80)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  owner User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tasks TaskTag[]

  @@unique([ownerId, normalizedName])
  @@index([ownerId, name])
  @@map("tags")
}

model TaskTag {
  taskId     String   @map("task_id") @db.Uuid
  tagId      String   @map("tag_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz(3)

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@index([tagId, taskId])
  @@map("task_tags")
}

model Reminder {
  id        String         @id @default(uuid()) @db.Uuid
  taskId    String         @map("task_id") @db.Uuid
  remindAt  DateTime       @map("remind_at") @db.Timestamptz(3)
  type      ReminderType   @default(CUSTOM)
  status    ReminderStatus @default(PENDING)
  sentAt    DateTime?      @map("sent_at") @db.Timestamptz(3)
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([status, remindAt])
  @@index([taskId, status])
  @@map("reminders")
}

model DailySummaryDelivery {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  localDate String   @map("local_date") @db.VarChar(10)
  sentAt    DateTime @default(now()) @map("sent_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, localDate])
  @@map("daily_summary_deliveries")
}

model ActivityEvent {
  id          String            @id @default(uuid()) @db.Uuid
  ownerId     String            @map("owner_id") @db.Uuid
  actorId     String            @map("actor_id") @db.Uuid
  type        ActivityEventType
  taskId      String?           @map("task_id") @db.Uuid
  projectId   String?           @map("project_id") @db.Uuid
  fileId      String?           @map("file_id") @db.Uuid
  title       String            @db.VarChar(500)
  metadata    Json?
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)

  owner User  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  task  Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([ownerId, createdAt])
  @@index([taskId])
  @@map("activity_events")
}

model Attachment {
  id           String   @id @default(uuid()) @db.Uuid
  ownerId      String   @map("owner_id") @db.Uuid
  uploadedById String   @map("uploaded_by_id") @db.Uuid
  taskId       String?  @map("task_id") @db.Uuid
  projectId    String?  @map("project_id") @db.Uuid
  delegatedTaskId String? @map("delegated_task_id") @db.Uuid
  fileName     String   @map("file_name") @db.VarChar(255)
  mimeType     String   @map("mime_type") @db.VarChar(255)
  sizeBytes    Int      @map("size_bytes")
  data         Bytes
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(3)

  owner      User     @relation("AttachmentOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  uploadedBy User     @relation("AttachmentUploader", fields: [uploadedById], references: [id], onDelete: Restrict)
  task       Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  project    Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  delegatedTask DelegatedTask? @relation(fields: [delegatedTaskId], references: [id], onDelete: Cascade)

  @@index([ownerId, createdAt])
  @@index([taskId])
  @@index([projectId])
  @@index([delegatedTaskId])
  @@map("attachments")
}

model AiAnalyticsConversation {
  id        String    @id @default(uuid()) @db.Uuid
  ownerId   String    @map("owner_id") @db.Uuid
  title     String    @default("AI-чат") @db.VarChar(200)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  archivedAt DateTime? @map("archived_at") @db.Timestamptz(3)

  owner    User                 @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  messages AiAnalyticsMessage[]

  @@index([ownerId, archivedAt, updatedAt])
  @@map("ai_analytics_conversations")
}

model AiAnalyticsMessage {
  id             String                 @id @default(uuid()) @db.Uuid
  conversationId String                 @map("conversation_id") @db.Uuid
  ownerId        String                 @map("owner_id") @db.Uuid
  role           AiAnalyticsMessageRole
  content        String                 @db.Text
  model          String?                @db.VarChar(120)
  artifacts      Json?
  metadata       Json?
  createdAt      DateTime               @default(now()) @map("created_at") @db.Timestamptz(3)

  conversation AiAnalyticsConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  owner        User                    @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([ownerId, createdAt])
  @@map("ai_analytics_messages")
}
